# Beckon environment. Copy to .env and fill in. Never commit a real .env.
# Values left blank are wired during activation (see Section 17 of the guide).
# The local infrastructure credentials below are safe dev defaults, not secrets.

# ---------------------------------------------------------------------------
# Core infrastructure (matches docker-compose.yml)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://beckon:beckon@localhost:5432/beckon
REDIS_URL=redis://localhost:6379

# S3 compatible object storage (MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=beckon
S3_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# App URLs
# ---------------------------------------------------------------------------
# Public origin of the console and runtime. Used to build install snippets and
# to validate embed origins. Set to your domain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Origin of the demo app (Section 13).
NEXT_PUBLIC_DEMO_URL=http://localhost:3100

# ---------------------------------------------------------------------------
# Auth.js
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Optional OAuth provider (enable in Section 17). GitHub shown as an example.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------------------------------------------------------------------------
# Encryption (host credentials at rest)
# ---------------------------------------------------------------------------
# 32 byte key, base64 encoded. Generate with: openssl rand -base64 32
# Required before storing real host API credentials in gateway configs.
BECKON_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Model and embedding providers (wired in Section 17)
# ---------------------------------------------------------------------------
# When both keys are empty, providers run in stub mode: deterministic mock
# responses so the app and evals run fully offline.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Default chat model id used when an agent does not specify one.
DEFAULT_MODEL=claude-3-5-sonnet-latest
# Embeddings: openai or stub.
EMBEDDING_PROVIDER=stub
EMBEDDING_MODEL=text-embedding-3-small
# Force stub providers even when keys are present (useful for tests and CI).
BECKON_STUB_LLM=false

# ---------------------------------------------------------------------------
# Transactional email (optional, wired in Section 17)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Beckon <noreply@localhost>
